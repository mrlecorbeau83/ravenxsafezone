# ============================================================
# Configuration SaveZone Bot (ravenXsavezone)
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# Token Discord du bot SaveZone
DISCORD_TOKEN=TON_TOKEN_SAVEZONE_ICI

# Préfixe des commandes préfixe (défaut: !)
BOT_PREFIX=!

# Identifiant unique de ce bot pour la communication inter-bots (ne pas changer)
BOT_NAME=savezone

# IMPORTANT : Même chemin que Raven pour la DB partagée
# Pointe vers : Raven_bot_complet_v3/data/database/global/global_lists.db
SHARED_GLOBAL_DB_PATH=/home/chrow/Bureau/Raven_bot_complet_v3/data/database/global/global_lists.db

# ID du propriétaire (doit être identique à Raven)
PROTECTED_USER_ID=1458518253373493353
