# ============================================================
# Configuration SafeZone Bot (ravenXsafezone)
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# Token Discord du bot SafeZone
DISCORD_TOKEN=TON_TOKEN_SAFEZONE_ICI

# Préfixe des commandes préfixe (défaut: !)
BOT_PREFIX=!

# Identifiant unique de ce bot pour la communication inter-bots (ne pas changer)
BOT_NAME=safezone

# IMPORTANT : Même chemin que Raven pour la DB partagée
# Pointe vers : Raven_bot_complet_v3/data/database/global/global_lists.db
SHARED_GLOBAL_DB_PATH=/chemin/vers/Raven_bot/data/database/global/global_lists.db
